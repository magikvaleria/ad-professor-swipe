---
import type { CollectionEntry } from 'astro:content';

interface Props {
  ad: CollectionEntry<'ads'>;
}

const { ad } = Astro.props;
const { slug, data } = ad;
---
<article class="group">
  <a href={`/ads/${slug}`} class="block no-underline">
    {data.thumbnail && (
      <div class="aspect-[4/3] overflow-hidden bg-ink/5 mb-4 border border-rule">
        <img
          src={data.thumbnail}
          alt={data.title}
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
        />
      </div>
    )}

    <div class="font-sans text-[11px] tracking-wide uppercase text-ink/50 mb-1">
      {data.kind} · {data.brand} · {data.year}
    </div>

    <h3 class="font-serif text-2xl leading-tight text-ink group-hover:text-accent transition-colors mb-3">
      {data.title}
    </h3>

    <div class="font-sans text-[13px] text-accent mb-3">
      <span class="mr-1">🧪</span><span class="font-medium">Principle:</span> {data.principle}
    </div>

    <div class="font-serif text-[15px] leading-relaxed text-ink/80 whitespace-pre-line">
      {data.breakdown}
    </div>
  </a>
</article>
