---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MechanismBadge from '../../components/MechanismBadge.astro';
import TagPill from '../../components/TagPill.astro';
import { aspectByName, aspectSlug } from '../../lib/cosmology';

export async function getStaticPaths() {
  const ads = (await getCollection('ads')).sort(
    (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
  );
  return ads.map((ad, i) => ({
    params: { slug: ad.slug },
    props: {
      ad,
      prev: ads[i + 1] ?? null,
      next: ads[i - 1] ?? null,
    },
  }));
}

interface Props {
  ad: CollectionEntry<'ads'>;
  prev: CollectionEntry<'ads'> | null;
  next: CollectionEntry<'ads'> | null;
}

const { ad, prev, next } = Astro.props;
const { data } = ad;
const { Content } = await ad.render();
const dateStr = data.publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---
<BaseLayout title={`${data.title} — ${data.brand} · Ad Swipe File`} description={data.insight.slice(0, 160)}>
  <article class="max-w-prose mx-auto px-6 pt-16 pb-12">
    <header class="mb-10">
      <div class="font-sans text-[11px] tracking-wide uppercase text-ink/50 mb-3">
        {data.kind} · {data.brand} · {data.year} · {data.medium}{data.agency ? ` · ${data.agency}` : ''}
      </div>
      <h1 class="font-serif text-4xl md:text-5xl leading-[1.1] text-ink">{data.title}</h1>
      <div class="font-sans text-xs text-ink/50 mt-4">Filed {dateStr}</div>
    </header>

    {data.embedUrl && (
      <div class="aspect-video w-full mb-12 border border-rule bg-ink/5">
        <iframe
          src={data.embedUrl}
          title={data.title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="w-full h-full"
        ></iframe>
      </div>
    )}

    <section class="mb-12 -mx-1 sm:-mx-3 px-6 py-6 bg-paper border border-rule">
      <div class="font-sans text-[12px] text-accent mb-2">
        <span class="mr-1">🧪</span><span class="font-medium uppercase tracking-wider">Principle</span>
      </div>
      <p class="font-serif text-2xl md:text-3xl leading-tight text-ink mb-4">{data.principle}</p>
      <div class="font-serif text-base leading-relaxed text-ink/85 whitespace-pre-line">
        {data.breakdown}
      </div>
    </section>

    {data.cosmologyContext && (
      <section class="mb-12 px-6 py-6 bg-ink/[0.02] border-l-2 border-accent">
        <div class="flex items-baseline justify-between mb-3">
          <div class="font-sans text-[12px] text-accent">
            <span class="mr-1">✦</span><span class="font-medium uppercase tracking-wider">The sky at filing</span>
          </div>
          <a href="/sky" class="font-sans text-[11px] text-ink/50 hover:text-accent">/sky →</a>
        </div>

        <div class="font-sans text-[11px] uppercase tracking-wide text-ink/50 mb-2">Window</div>
        <div class="font-serif text-base text-ink mb-4">{data.cosmologyContext.window}</div>

        <div class="font-sans text-[11px] uppercase tracking-wide text-ink/50 mb-2">Resonant aspects</div>
        <ul class="font-serif text-base text-ink mb-5 space-y-1">
          {data.cosmologyContext.resonantAspects.map((name) => {
            const a = aspectByName(name);
            return (
              <li>
                <a href={`/sky#${aspectSlug(name)}`} class="text-ink hover:text-accent">
                  {name}
                </a>
                {a && <span class="text-ink/55 italic text-sm"> — {a.meaning.split('. ')[0]}.</span>}
              </li>
            );
          })}
        </ul>

        {data.cosmologyContext.historicalEcho && (
          <>
            <div class="font-sans text-[11px] uppercase tracking-wide text-ink/50 mb-2">Historical echo</div>
            <div class="font-serif text-base text-ink/85 leading-relaxed whitespace-pre-line mb-5">
              {data.cosmologyContext.historicalEcho}
            </div>
          </>
        )}

        <div class="font-sans text-[11px] uppercase tracking-wide text-ink/50 mb-2">Why this template, in this sky</div>
        <div class="font-serif text-base text-ink/85 leading-relaxed whitespace-pre-line mb-5">
          {data.cosmologyContext.framingNotes}
        </div>

        {data.cosmologyContext.feedsAngles.length > 0 && (
          <>
            <div class="font-sans text-[11px] uppercase tracking-wide text-ink/50 mb-2">Feeds the Ad Factory angles</div>
            <ul class="space-y-3">
              {data.cosmologyContext.feedsAngles.map((f) => (
                <li class="font-serif text-[15px] text-ink/85 leading-relaxed">
                  <span class="font-sans text-[11px] font-medium text-accent">{f.persona} × {f.angle}</span>
                  <div class="text-ink/80">{f.cosmologyLink}</div>
                </li>
              ))}
            </ul>
          </>
        )}
      </section>
    )}

    <div class="mb-12 font-sans text-[11px] tracking-wider uppercase text-ink/40 text-center">
      ⸻ The deep dive ⸻
    </div>

    <section class="mb-10">
      <h2 class="font-sans text-[11px] uppercase tracking-wider text-ink/50 mb-3">Hook</h2>
      <p class="font-serif text-lg leading-relaxed text-ink">{data.hook}</p>
    </section>

    <section class="mb-10">
      <h2 class="font-sans text-[11px] uppercase tracking-wider text-ink/50 mb-3">Insight</h2>
      <p class="font-serif text-lg leading-relaxed text-ink">{data.insight}</p>
    </section>

    <section class="mb-10">
      <h2 class="font-sans text-[11px] uppercase tracking-wider text-ink/50 mb-3">Mechanisms</h2>
      <div class="flex flex-wrap gap-2">
        {data.mechanisms.map((m) => <MechanismBadge name={m} />)}
      </div>
    </section>

    <section class="mb-10">
      <h2 class="font-sans text-[11px] uppercase tracking-wider text-ink/50 mb-3">Structure</h2>
      <div class="font-serif text-lg leading-relaxed text-ink whitespace-pre-line">{data.structure}</div>
    </section>

    <section class="mb-10">
      <h2 class="font-sans text-[11px] uppercase tracking-wider text-ink/50 mb-3">Template</h2>
      <div class="bg-ink/[0.03] border-l-2 border-accent/40 px-5 py-4 font-serif text-base leading-relaxed text-ink whitespace-pre-line">{data.template}</div>
    </section>

    <section class="mb-12">
      <h2 class="font-sans text-[11px] uppercase tracking-wider text-ink/50 mb-3">Applied example</h2>
      <div class="bg-ink/[0.03] border-l-2 border-accent/40 px-5 py-4 font-serif text-base leading-relaxed text-ink whitespace-pre-line">{data.appliedExample}</div>
    </section>

    {data.creatives && data.creatives.length > 0 && (
      <section class="mb-12 pt-8 border-t border-rule">
        <div class="font-sans text-[11px] uppercase tracking-wider text-ink/50 mb-3">Output → Ad Factory</div>
        <p class="font-serif text-base text-ink/80 mb-5 leading-relaxed">
          {data.creatives.length} Meta ad {data.creatives.length === 1 ? 'creative was' : 'creatives were'} derived from this template — one per persona.
        </p>
        <ul class="space-y-2 font-sans text-sm">
          {data.creatives.map((c) => (
            <li>
              <a href={`http://localhost:4322/creatives/${c.trackingName}`} class="text-ink hover:text-accent flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <span class="font-mono text-[11px] text-accent">{c.angle}</span>
                <span class="font-medium">{c.persona}</span>
                <span class="text-ink/60 italic">{c.headline}</span>
              </a>
            </li>
          ))}
        </ul>
        <a href="http://localhost:4322" class="inline-block mt-4 text-xs text-ink/60 hover:text-accent">
          View all creatives in Ad Factory →
        </a>
      </section>
    )}

    <div class="font-serif text-base text-ink/85 leading-relaxed [&>p]:mb-4 [&>p:last-child]:mb-0">
      <Content />
    </div>

    {data.tags.length > 0 && (
      <div class="mt-12 pt-6 border-t border-rule">
        {data.tags.map((t) => <TagPill tag={t} />)}
      </div>
    )}

    {data.adUrl && (
      <div class="mt-8 font-sans text-xs text-ink/50">
        Source:{' '}
        <a href={data.adUrl} target="_blank" rel="noopener" class="hover:text-accent">
          {new URL(data.adUrl).hostname}
        </a>
      </div>
    )}

    <nav class="mt-16 pt-8 border-t border-rule grid grid-cols-2 gap-6 font-sans text-sm">
      <div>
        {prev && (
          <a href={`/ads/${prev.slug}`} class="block group no-underline">
            <div class="text-[11px] uppercase tracking-wide text-ink/50 mb-1">← Older</div>
            <div class="text-ink group-hover:text-accent">{prev.data.title}</div>
          </a>
        )}
      </div>
      <div class="text-right">
        {next && (
          <a href={`/ads/${next.slug}`} class="block group no-underline">
            <div class="text-[11px] uppercase tracking-wide text-ink/50 mb-1">Newer →</div>
            <div class="text-ink group-hover:text-accent">{next.data.title}</div>
          </a>
        )}
      </div>
    </nav>
  </article>
</BaseLayout>
