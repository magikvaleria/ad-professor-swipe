---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ad Swipe File',
  description = 'A daily archive of ads that work, and why.',
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Ad Swipe File" href="/rss.xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600&display=swap"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-rule">
      <div class="max-w-6xl mx-auto px-6 py-6 flex flex-wrap items-baseline justify-between gap-4 font-sans">
        <a href="/" class="text-base font-semibold tracking-tight text-ink hover:text-accent">
          Ad Swipe File
        </a>
        <nav class="text-sm flex gap-6">
          <a href="/" class={isActive('/') ? 'text-accent' : 'text-ink/70 hover:text-ink'}>Latest</a>
          <a href="/archive" class={isActive('/archive') ? 'text-accent' : 'text-ink/70 hover:text-ink'}>Archive</a>
          <a href="/about" class={isActive('/about') ? 'text-accent' : 'text-ink/70 hover:text-ink'}>About</a>
          <a href="/rss.xml" class="text-ink/70 hover:text-ink">RSS</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-rule mt-24">
      <div class="max-w-6xl mx-auto px-6 py-8 flex flex-wrap items-baseline justify-between gap-4 font-sans text-xs text-ink/60">
        <span>A daily archive of ads that work, and why.</span>
        <a href="/rss.xml" class="hover:text-accent">Subscribe via RSS</a>
      </div>
    </footer>
  </body>
</html>
